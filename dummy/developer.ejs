<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Developer - Adil ur Rehman Kakar</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        /* ============================================
           DEVELOPER PAGE - SELF-CONTAINED STYLES
           Copy this entire file to use in other projects
           ============================================ */
        
        :root {
            --primary-color: #007bff;
            --primary-dark: #0056b3;
            --secondary-color: #6610f2;
            --accent-color: #e83e8c;
            --success-color: #28a745;
            --danger-color: #dc3545;
            --warning-color: #ffc107;
            --info-color: #17a2b8;
            
            /* Dark Theme Colors */
            --dark-bg: #0f0f1a;
            --dark-surface: #1a1a2e;
            --dark-card: #16213e;
            --dark-text: #ffffff;
            --dark-text-muted: #adb5bd;
            --dark-border: rgba(255, 255, 255, 0.1);
            
            /* Light Theme Colors */
            --light-bg: #f8f9fa;
            --light-surface: #ffffff;
            --light-card: #ffffff;
            --light-text: #212529;
            --light-text-muted: #6c757d;
            --light-border: rgba(0, 0, 0, 0.1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            min-height: 100vh;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        /* ========== DARK THEME ========== */
        .dark-theme {
            background: linear-gradient(135deg, var(--dark-bg) 0%, #0d1b2a 50%, #1b263b 100%);
            color: var(--dark-text);
        }

        /* ========== LIGHT THEME ========== */
        .light-theme {
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 50%, #dee2e6 100%);
            color: var(--light-text);
        }

        /* ========== THEME TOGGLE BUTTON ========== */
        .theme-toggle-wrapper {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 1000;
        }

        .theme-toggle-btn {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        }

        .dark-theme .theme-toggle-btn {
            background: linear-gradient(135deg, #ffd700, #ff8c00);
            color: #1a1a2e;
        }

        .light-theme .theme-toggle-btn {
            background: linear-gradient(135deg, #1a1a2e, #2d1b4e);
            color: #ffd700;
        }

        .theme-toggle-btn:hover {
            transform: scale(1.1) rotate(15deg);
            box-shadow: 0 6px 25px rgba(0, 0, 0, 0.3);
        }

        /* ========== HERO SECTION ========== */
        .developer-hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
            position: relative;
            overflow: hidden;
        }

        .hero-particles {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            pointer-events: none;
        }

        .hero-particles::before,
        .hero-particles::after {
            content: '';
            position: absolute;
            border-radius: 50%;
            animation: float 20s infinite;
        }

        .dark-theme .hero-particles::before {
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(0, 123, 255, 0.15) 0%, transparent 70%);
            top: -100px;
            left: -100px;
        }

        .dark-theme .hero-particles::after {
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(111, 66, 193, 0.15) 0%, transparent 70%);
            bottom: -50px;
            right: -50px;
            animation-delay: -10s;
        }

        .light-theme .hero-particles::before {
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(0, 123, 255, 0.1) 0%, transparent 70%);
            top: -100px;
            left: -100px;
        }

        .light-theme .hero-particles::after {
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(111, 66, 193, 0.1) 0%, transparent 70%);
            bottom: -50px;
            right: -50px;
            animation-delay: -10s;
        }

        @keyframes float {
            0%, 100% { transform: translate(0, 0) rotate(0deg); }
            25% { transform: translate(30px, 30px) rotate(5deg); }
            50% { transform: translate(0, 50px) rotate(0deg); }
            75% { transform: translate(-30px, 30px) rotate(-5deg); }
        }

        /* ========== DEVELOPER CARD ========== */
        .developer-card {
            max-width: 900px;
            width: 100%;
            border-radius: 30px;
            position: relative;
            overflow: hidden;
            transition: all 0.5s ease;
        }

        .dark-theme .developer-card {
            background: linear-gradient(135deg, #1e3a5f 0%, #1a1a2e 50%, #2d1b4e 100%);
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5);
        }

        .light-theme .developer-card {
            background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.1);
            border: 1px solid rgba(0, 0, 0, 0.05);
        }

        .developer-card:hover {
            transform: translateY(-10px);
        }

        .dark-theme .developer-card:hover {
            box-shadow: 0 35px 70px rgba(0, 0, 0, 0.6);
        }

        .light-theme .developer-card:hover {
            box-shadow: 0 35px 70px rgba(0, 0, 0, 0.15);
        }

        .developer-bg-pattern {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
        }

        .dark-theme .developer-bg-pattern {
            background: 
                radial-gradient(circle at 0% 0%, rgba(0, 123, 255, 0.15) 0%, transparent 50%),
                radial-gradient(circle at 100% 100%, rgba(111, 66, 193, 0.15) 0%, transparent 50%);
        }

        .light-theme .developer-bg-pattern {
            background: 
                radial-gradient(circle at 0% 0%, rgba(0, 123, 255, 0.08) 0%, transparent 50%),
                radial-gradient(circle at 100% 100%, rgba(111, 66, 193, 0.08) 0%, transparent 50%);
        }

        .developer-content {
            position: relative;
            z-index: 1;
            padding: 60px;
        }

        /* ========== DEVELOPER BADGE ========== */
        .developer-badge {
            display: inline-block;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            color: white;
            padding: 12px 30px;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 30px;
            box-shadow: 0 10px 30px rgba(0, 123, 255, 0.3);
        }

        /* ========== AVATAR SECTION ========== */
        .developer-avatar-wrapper {
            position: relative;
            width: 220px;
            height: 220px;
            margin: 0 auto 30px;
        }

        .avatar-ring {
            position: absolute;
            top: -12px;
            left: -12px;
            width: 244px;
            height: 244px;
            border: 4px solid transparent;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color), var(--accent-color), var(--primary-color)) border-box;
            -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
            mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            animation: ringRotate 4s linear infinite;
        }

        @keyframes ringRotate {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .developer-avatar {
            width: 220px;
            height: 220px;
            border-radius: 50%;
            object-fit: cover;
            border: 5px solid var(--dark-surface);
            transition: all 0.3s ease;
        }

        .light-theme .developer-avatar {
            border-color: var(--light-surface);
        }

        .avatar-status {
            position: absolute;
            bottom: 18px;
            right: 18px;
            width: 30px;
            height: 30px;
            background: var(--success-color);
            border-radius: 50%;
            border: 5px solid var(--dark-surface);
            animation: statusPulse 2s ease-in-out infinite;
        }

        .light-theme .avatar-status {
            border-color: var(--light-surface);
        }

        @keyframes statusPulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(40, 167, 69, 0.5); }
            50% { box-shadow: 0 0 0 12px rgba(40, 167, 69, 0); }
        }

        /* ========== DEVELOPER INFO ========== */
        .developer-name {
            font-size: 2.8rem;
            font-weight: 800;
            margin-bottom: 15px;
            background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .developer-title {
            font-size: 1.3rem;
            font-weight: 600;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .dark-theme .developer-title {
            color: var(--primary-color);
        }

        .light-theme .developer-title {
            color: var(--primary-dark);
        }

        .developer-education {
            font-size: 1.1rem;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .dark-theme .developer-education {
            color: var(--dark-text-muted);
        }

        .light-theme .developer-education {
            color: var(--light-text-muted);
        }

        .developer-bio {
            font-size: 1.1rem;
            line-height: 1.9;
            margin-bottom: 30px;
        }

        .dark-theme .developer-bio {
            color: #d1d5db;
        }

        .light-theme .developer-bio {
            color: #4a5568;
        }

        /* ========== SKILLS SECTION ========== */
        .skills-section {
            margin-bottom: 35px;
        }

        .skills-title {
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .dark-theme .skills-title {
            color: var(--warning-color);
        }

        .light-theme .skills-title {
            color: #856404;
        }

        .skills-container {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .skill-badge {
            padding: 8px 16px;
            border-radius: 25px;
            font-size: 0.85rem;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .dark-theme .skill-badge {
            background: rgba(255, 255, 255, 0.1);
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .light-theme .skill-badge {
            background: rgba(0, 123, 255, 0.1);
            color: var(--primary-dark);
            border: 1px solid rgba(0, 123, 255, 0.2);
        }

        .skill-badge:hover {
            transform: translateY(-3px);
        }

        .dark-theme .skill-badge:hover {
            background: rgba(0, 123, 255, 0.3);
            box-shadow: 0 5px 15px rgba(0, 123, 255, 0.3);
        }

        .light-theme .skill-badge:hover {
            background: rgba(0, 123, 255, 0.2);
            box-shadow: 0 5px 15px rgba(0, 123, 255, 0.2);
        }

        /* ========== STATS SECTION ========== */
        .stats-section {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 35px;
            padding: 25px;
            border-radius: 20px;
        }

        .dark-theme .stats-section {
            background: rgba(0, 0, 0, 0.2);
        }

        .light-theme .stats-section {
            background: rgba(0, 0, 0, 0.03);
        }

        .stat-item {
            text-align: center;
        }

        .stat-number {
            font-size: 2rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .stat-label {
            font-size: 0.85rem;
            font-weight: 500;
        }

        .dark-theme .stat-label {
            color: var(--dark-text-muted);
        }

        .light-theme .stat-label {
            color: var(--light-text-muted);
        }

        /* ========== SOCIAL BUTTONS ========== */
        .developer-social {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
        }

        .social-btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 14px 24px;
            border-radius: 14px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            border: 2px solid transparent;
        }

        .social-btn i {
            font-size: 1.2rem;
        }

        .social-email {
            background: rgba(220, 53, 69, 0.15);
            color: var(--danger-color);
            border-color: rgba(220, 53, 69, 0.3);
        }

        .social-email:hover {
            background: var(--danger-color);
            color: white;
            transform: translateY(-4px);
            box-shadow: 0 12px 30px rgba(220, 53, 69, 0.4);
        }

        .social-linkedin {
            background: rgba(0, 119, 181, 0.15);
            color: #0077b5;
            border-color: rgba(0, 119, 181, 0.3);
        }

        .social-linkedin:hover {
            background: #0077b5;
            color: white;
            transform: translateY(-4px);
            box-shadow: 0 12px 30px rgba(0, 119, 181, 0.4);
        }

        .social-instagram {
            background: rgba(225, 48, 108, 0.15);
            color: #e1306c;
            border-color: rgba(225, 48, 108, 0.3);
        }

        .social-instagram:hover {
            background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
            color: white;
            transform: translateY(-4px);
            box-shadow: 0 12px 30px rgba(225, 48, 108, 0.4);
        }

        .social-github {
            border-color: rgba(255, 255, 255, 0.2);
        }

        .dark-theme .social-github {
            background: rgba(255, 255, 255, 0.1);
            color: #fff;
        }

        .light-theme .social-github {
            background: rgba(0, 0, 0, 0.1);
            color: #333;
            border-color: rgba(0, 0, 0, 0.2);
        }

        .social-github:hover {
            background: #333;
            color: white;
            transform: translateY(-4px);
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.4);
        }

        .social-website {
            background: rgba(0, 123, 255, 0.15);
            color: var(--primary-color);
            border-color: rgba(0, 123, 255, 0.3);
        }

        .social-website:hover {
            background: var(--primary-color);
            color: white;
            transform: translateY(-4px);
            box-shadow: 0 12px 30px rgba(0, 123, 255, 0.4);
        }

        /* ========== BACK BUTTON ========== */
        .back-btn-wrapper {
            position: fixed;
            top: 20px;
            left: 20px;
            z-index: 1000;
        }

        .back-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 12px 24px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
            border: 2px solid transparent;
        }

        .dark-theme .back-btn {
            background: rgba(255, 255, 255, 0.1);
            color: #fff;
            border-color: rgba(255, 255, 255, 0.2);
        }

        .light-theme .back-btn {
            background: rgba(0, 0, 0, 0.05);
            color: #333;
            border-color: rgba(0, 0, 0, 0.1);
        }

        .back-btn:hover {
            transform: translateX(-5px);
        }

        .dark-theme .back-btn:hover {
            background: rgba(255, 255, 255, 0.2);
            color: #fff;
        }

        .light-theme .back-btn:hover {
            background: rgba(0, 0, 0, 0.1);
            color: #333;
        }

        /* ========== RESPONSIVE DESIGN ========== */
        @media (max-width: 768px) {
            .developer-content {
                padding: 40px 25px;
            }

            .developer-avatar-wrapper {
                width: 160px;
                height: 160px;
            }

            .avatar-ring {
                width: 184px;
                height: 184px;
            }

            .developer-avatar {
                width: 160px;
                height: 160px;
            }

            .developer-name {
                font-size: 2rem;
            }

            .developer-title,
            .developer-education {
                font-size: 1rem;
                justify-content: center;
            }

            .developer-bio {
                font-size: 1rem;
                text-align: center;
            }

            .skills-title {
                justify-content: center;
            }

            .skills-container {
                justify-content: center;
            }

            .stats-section {
                grid-template-columns: repeat(3, 1fr);
                gap: 15px;
                padding: 20px 15px;
            }

            .stat-number {
                font-size: 1.5rem;
            }

            .stat-label {
                font-size: 0.75rem;
            }

            .developer-social {
                justify-content: center;
            }

            .social-btn {
                padding: 12px 18px;
                font-size: 0.9rem;
            }

            .social-btn span {
                display: none;
            }

            .theme-toggle-wrapper {
                top: 15px;
                right: 15px;
            }

            .back-btn-wrapper {
                top: 15px;
                left: 15px;
            }

            .back-btn span {
                display: none;
            }

            .back-btn {
                padding: 12px;
                border-radius: 50%;
            }
        }

        @media (max-width: 480px) {
            .developer-content {
                padding: 30px 20px;
            }

            .developer-avatar-wrapper {
                width: 130px;
                height: 130px;
            }

            .avatar-ring {
                width: 154px;
                height: 154px;
            }

            .developer-avatar {
                width: 130px;
                height: 130px;
            }

            .avatar-status {
                width: 22px;
                height: 22px;
                bottom: 10px;
                right: 10px;
            }

            .developer-name {
                font-size: 1.6rem;
            }

            .developer-badge {
                font-size: 0.75rem;
                padding: 10px 20px;
            }

            .stats-section {
                grid-template-columns: 1fr;
                gap: 15px;
            }
        }

        /* ========== ANIMATIONS ========== */
        .fade-in {
            animation: fadeIn 0.8s ease forwards;
        }

        .fade-in-delay-1 { animation-delay: 0.2s; opacity: 0; }
        .fade-in-delay-2 { animation-delay: 0.4s; opacity: 0; }
        .fade-in-delay-3 { animation-delay: 0.6s; opacity: 0; }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
